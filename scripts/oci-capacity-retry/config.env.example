# OCI A1.Flex capacity retry — 인스턴스/네트워크/이미지 OCID 설정
#
# 사용법:
#   1. 이 파일을 ~/oci-capacity-retry/config.env 로 복사
#   2. 모든 <PLACEHOLDER> 를 실제 값으로 채움
#   3. retry.sh 실행으로 검증
#
# OCID 수집 방법은 docs/oci-capacity-retry.md "OCID 수집" 섹션 참조.

# tenancy OCID — root compartment 와 동일.
# 콘솔: Profile → Tenancy: <name> → OCID 복사
export OCI_COMPARTMENT_ID="<TENANCY_OCID>"

# Availability Domain 정식 이름 (한국 리전은 단일 AD).
# `oci iam availability-domain list --compartment-id $OCI_COMPARTMENT_ID --query 'data[0].name'`
# 형식: "fXgx:AP-CHUNCHEON-1-AD-1" (춘천) 또는 "Uocm:AP-SEOUL-1-AD-1" (서울)
export OCI_AD_NAME="<AD_NAME>"

# Public subnet OCID (kuberport-vcn 의 public subnet).
# `oci network subnet list --compartment-id $OCI_COMPARTMENT_ID --query 'data[?contains("display-name",`public`)].id|[0]'`
export OCI_SUBNET_ID="<SUBNET_OCID>"

# Ubuntu 24.04 Minimal aarch64 최신 이미지 OCID (리전별로 다름).
# `oci compute image list --compartment-id $OCI_COMPARTMENT_ID \
#    --operating-system "Canonical Ubuntu" --operating-system-version "24.04 Minimal aarch64" \
#    --shape VM.Standard.A1.Flex --sort-by TIMECREATED --sort-order DESC --limit 1 \
#    --query 'data[0].id'`
export OCI_IMAGE_ID="<IMAGE_OCID>"

# === 인스턴스 사양 (보통 안 바꿔도 됨 — Always Free 한도 풀로) ===
export OCI_INSTANCE_NAME="kuberport"
export OCI_SHAPE="VM.Standard.A1.Flex"
export OCI_OCPUS=4              # Always Free A1 한도: 총 4 OCPU
export OCI_MEMORY_GB=24         # Always Free A1 한도: 총 24 GB
export OCI_BOOT_VOL_GB=100      # Always Free block 한도: 총 200 GB

# SSH 공개키 경로 — ~/.ssh/oci_kuberport.pub 권장 (CLAUDE.md 규약)
export OCI_SSH_PUB_KEY="$HOME/.ssh/oci_kuberport.pub"
